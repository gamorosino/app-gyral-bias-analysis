{\n  "name": "analyze_gyral_bias",\n  "version": "0.1.0",\n  "description": "A Brainlife app for analyzing gyral bias in structural neuroimaging data.",\n  "options": [\n    {\n      "name": "parc",\n      "type": "file",\n      "description": "Input parcellation NIfTI file (parc.nii.gz)"\n    },\n    {\n      "name": "labels",\n      "type": "file",\n      "description": "JSON file containing label definitions (label.json)"\n    },\n    {\n      "name": "tracks",\n      "type": "folder",\n      "description": "Input track files (track{parcel_id}.tck)"\n    },\n    {\n      "name": "freesurfer",\n      "type": "folder",\n      "description": "FreeSurfer directory"\n    },\n    {\n      "name": "config",\n      "type": "file",\n      "description": "Configuration file (config.json)"\n    }\n  ],\n  "outputs": [\n    {\n      "name": "curvature_streamlines",\n      "type": "file",\n      "description": "Output CSV file with curvature streamlines data"\n    }\n  ]\n}