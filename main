#!/bin/bash
#PBS -l nodes=1:ppn=1,vmem=8g,walltime=3:00:00
#PBS -N app-gyral-bias-analysis
#PBS -V

set -euo pipefail
set -x

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONTAINER_IMAGE="docker://gamorosino/tract_align:v1.0"
CONFIG="${SCRIPT_DIR}/config.json"
WORK="${SCRIPT_DIR}/work_gyral_bias"

if [[ ! -f "$CONFIG" ]]; then
  echo "[ERROR] Missing $CONFIG"
  exit 1
fi

# initialize vars so set -u never explodes on unset names
INPUT_MODE=""
PARC=""
LABEL=""
TCKS=""
TRACTOGRAM=""
ECC=""
POLAR=""
VAREA=""
ECC_BINS=""
POLAR_BINS=""
FS_OUTPUT=""
SUBJECT_ID=""
VISUAL_AREA_A=""
VISUAL_AREA_B=""
PARC_VAREAS=""
MERIDIAN_MODE=""
ROI_ORDER="0"
MAKE_PLOTS="1"
ONLY_KDE="0"
NORMALIZE="0"
EXPORTS="$(
CONFIG_PATH="$CONFIG" python3 - <<'PY'
import json, os, shlex
from pathlib import Path

cfg = json.loads(Path(os.environ["CONFIG_PATH"]).read_text())

def get(key, default=""):
    v = cfg.get(key, default)
    if isinstance(v, str) and v.strip() == "":
        return ""
    return v

def get_bool(key, default=False):
    return bool(cfg.get(key, default))

def get_subject_id(cfg):
    for item in cfg.get("_inputs", []):
        if item.get("id") == "freesurfer":
            subj = (item.get("meta") or {}).get("subject")
            if subj is not None and str(subj).strip():
                return str(subj).strip()

    for section in ("_inputs", "_outputs"):
        for item in cfg.get(section, []):
            subj = (item.get("meta") or {}).get("subject")
            if subj is not None and str(subj).strip():
                return str(subj).strip()
    return ""

input_mode = get("input_mode", "precomputed_tcks")

# existing inputs
parc = get("parc")
label = get("label")
tcks = get("tcks")
fs_output = get("output")
subject_id = get_subject_id(cfg)

# whole-tractogram inputs
tractogram = get("track")
ecc = get("eccentricity")
polar = get("polarAngle")
varea = get("varea")
ecc_bins = get("ecc_bins", "0_2,2_4,4_6,6_8,8_90")
polar_bins = get("polar_bins", "0_15,30_60,75_105,120_150,165_180")

visual_area_a = get("visual_area_a")
visual_area_b = get("visual_area_b")
roi_order = get_bool("roi_order", False)
parc_vareas = get("parc_vareas")

make_plots = get_bool("make_plots", True)
only_kde = get_bool("only_kde", False)
meridian_mode = get("meridian_mode", "hm_vm_lvm_uvm")
normalize = get_bool("normalize", False)
print(f"export NORMALIZE={'1' if normalize else '0'}")
missing_common = [k for k, v in [
    ("output", fs_output),
    ("subject_id", subject_id),
] if not v]

if input_mode == "precomputed_tcks":
    missing_mode = [k for k, v in [
        ("parc", parc),
        ("label", label),
        ("tcks", tcks),
    ] if not v]
elif input_mode == "whole_tractogram":
    missing_mode = [k for k, v in [
        ("tractogram", tractogram),
        ("ecc", ecc),
        ("varea", varea),
    ] if not v]
else:
    raise SystemExit(f"[ERROR] Unknown input_mode: {input_mode}")

missing = missing_common + missing_mode
if missing:
    raise SystemExit(f"[ERROR] Missing required config keys: {missing}")

filtering_requested = bool(visual_area_a.strip()) or bool(visual_area_b.strip()) or roi_order

if input_mode == "precomputed_tcks":
    if filtering_requested and not parc_vareas:
        raise SystemExit("[ERROR] input_mode=precomputed_tcks: filtering requested but parc_vareas is missing")

# in whole_tractogram mode → varea is used instead, so no error

def exp(name, value):
    print(f'export {name}={shlex.quote(str(value))}')

exp("INPUT_MODE", input_mode)

exp("PARC", parc)
exp("LABEL", label)
exp("TCKS", tcks)

exp("TRACTOGRAM", tractogram)
exp("ECC", ecc)
exp("POLAR", polar)
exp("VAREA", varea)
exp("ECC_BINS", ecc_bins)
exp("POLAR_BINS", polar_bins)

exp("FS_OUTPUT", fs_output)
exp("SUBJECT_ID", subject_id)
exp("VISUAL_AREA_A", visual_area_a)
exp("VISUAL_AREA_B", visual_area_b)
exp("PARC_VAREAS", parc_vareas)
exp("MERIDIAN_MODE", meridian_mode)

print(f"export ROI_ORDER={'1' if roi_order else '0'}")
print(f"export MAKE_PLOTS={'1' if make_plots else '0'}")
print(f"export ONLY_KDE={'1' if only_kde else '0'}")
PY
)" || {
  echo "[ERROR] Failed to parse config.json"
  exit 1
}

eval "$EXPORTS"

: "${FS_OUTPUT:?ERROR: FS_OUTPUT was not set (missing 'output' in config.json)}"
: "${SUBJECT_ID:?ERROR: SUBJECT_ID was not set}"
: "${INPUT_MODE:?ERROR: INPUT_MODE was not set}"

run_in_env() {
    singularity exec -e \
        "${CONTAINER_IMAGE}" \
        micromamba run -n tract_align "$@"
}

mkdir -p "$WORK/surf2vol"

if [[ -z "${FREESURFER_LICENSE:-}" ]]; then
  echo "[ERROR] FREESURFER_LICENSE env var is not set"
  exit 1
fi
printf "%s\n" "$FREESURFER_LICENSE" > "$WORK/license.txt"

cp "${SCRIPT_DIR}/freesurfer.sh" "$WORK/freesurfer.sh"
chmod +x "$WORK/freesurfer.sh"

echo "[INFO] Running FreeSurfer mri_surf2vol inside brainlife/freesurfer:7.3.2"

time singularity exec -e \
  -B "${WORK}/license.txt:/usr/local/freesurfer/license.txt" \
  -B "${WORK}:/work" \
  docker://brainlife/freesurfer:7.3.2 \
  bash /work/freesurfer.sh "$FS_OUTPUT" /work/surf2vol

LH_CURV="$WORK/surf2vol/lh.curv.mgz"
RH_CURV="$WORK/surf2vol/rh.curv.mgz"

[[ ! -f "$LH_CURV" ]] && echo "[ERROR] Missing expected $LH_CURV" && exit 1
[[ ! -f "$RH_CURV" ]] && echo "[ERROR] Missing expected $RH_CURV" && exit 1

mkdir -p "${SCRIPT_DIR}/output" "${SCRIPT_DIR}/plots"

CMD=(python3 "${SCRIPT_DIR}/analyze_gyral_bias_app.py"
  --input_mode "$INPUT_MODE"
  --lh_curv "$LH_CURV"
  --rh_curv "$RH_CURV"
  --output_csv "${SCRIPT_DIR}/output/tractmeasures.csv"
  --subject_id "$SUBJECT_ID"
  --plots_dir "${SCRIPT_DIR}/plots"
  --meridian_mode "$MERIDIAN_MODE"
  --visual_area_a "$VISUAL_AREA_A"
  --visual_area_b "$VISUAL_AREA_B"
)

if [[ "$INPUT_MODE" == "precomputed_tcks" ]]; then
  CMD+=(
    --parc "$PARC"
    --label_json "$LABEL"
    --tcks_dir "$TCKS"
  )
elif [[ "$INPUT_MODE" == "whole_tractogram" ]]; then
  CMD+=(
    --tractogram "$TRACTOGRAM"
    --ecc "$ECC"
    --varea "$VAREA"
    --ecc_bins "$ECC_BINS"
    --polar_bins "$POLAR_BINS"
  )

  if [[ -n "${POLAR:-}" ]]; then
    CMD+=(--polar "$POLAR")
  fi
fi

if [[ "$MAKE_PLOTS" == "1" ]]; then
  CMD+=(--make_plots)
fi

if [[ "$ONLY_KDE" == "1" ]]; then
  CMD+=(--only_kde)
fi

if [[ -n "${PARC_VAREAS:-}" ]]; then
  CMD+=(--parc_vareas "$PARC_VAREAS")
fi

if [[ "$ROI_ORDER" == "1" ]]; then
  CMD+=(--roi_order)
fi

if [[ "$NORMALIZE" == "1" ]]; then
  CMD+=(--normalize)
fi

echo "[INFO] Running: ${CMD[*]}"
run_in_env "${CMD[@]}"

echo "[INFO] Done. Output: ${SCRIPT_DIR}/output/tractmeasures.csv"

if [[ "$MAKE_PLOTS" == "1" ]]; then
  bash "${SCRIPT_DIR}/generate_product_json.sh" "${SCRIPT_DIR}/plots/" "${SCRIPT_DIR}/product.json"
fi
