#!/bin/bash
set -euo pipefail

[ -z "${FREESURFER_LICENSE:-}" ] && echo "[ERROR] FREESURFER_LICENSE env var is not set" && exit 1
printf "%s\n" "$FREESURFER_LICENSE" > /tmp/license.txt
WORK=/tmp/work_gyral_bias
mkdir -p "$WORK/surf2vol"
CONFIG=/input/config.json

if [[ ! -f "$CONFIG" ]]; then
  echo "[ERROR] Missing /input/config.json"
  exit 1
fi

# read json with python (jq not guaranteed)
python3 - <<'PY'
import json, os, sys, subprocess
from pathlib import Path

cfg_path = Path("/input/config.json")
cfg = json.loads(cfg_path.read_text())

def get(key, default=None):
    v = cfg.get(key, default)
    if isinstance(v, str) and v.strip() == "":
        return default
    return v

parc = get("parc")
label = get("label")
tcks = get("tcks")
fs_output = get("output")  # FreeSurfer SUBJECT dir (contains mri/ surf/)

visual_area_a = get("visual_area_a", "")
visual_area_b = get("visual_area_b", "")
roi_order = bool(cfg.get("roi_order", False))
parc_vareas = get("parc_vareas", None)

missing = [k for k,v in [("parc",parc),("label",label),("tcks",tcks),("output",fs_output)] if not v]
if missing:
    print(f"[ERROR] Missing required config keys: {missing}", file=sys.stderr)
    sys.exit(1)

# Fail-fast rule if filtering requested
filtering_requested = bool(visual_area_a) or bool(visual_area_b) or roi_order
if filtering_requested and not parc_vareas:
    print("[ERROR] visual area filtering requested (visual_area_a/visual_area_b/roi_order), but parc_vareas is missing.", file=sys.stderr)
    sys.exit(1)

singularity exec -e \
  -B /tmp/license.txt:/usr/local/freesurfer/license.txt \
  -B "$fs_output":/fs \
  -B "$WORK":/work \
  docker://brainlife/freesurfer:7.3.2 \
  /bin/bash -lc "/work/freesurfer.sh /fs /work/surf2vol"

# Build command
cmd = [
  "python3", "/opt/app/analyze_gyral_bias_app.py",
  "--parc", parc,
  "--label_json", label,
  "--tcks_dir", tcks,
  "--freesurfer_dir", fs_output,
  "--output_csv", "/output/curvature_streamlines.csv",
  "--visual_area_a", visual_area_a,
  "--visual_area_b", visual_area_b,
]
if parc_vareas:
    cmd += ["--parc_vareas", parc_vareas]
if roi_order:
    cmd += ["--roi_order"]

print("[INFO] Running:", " ".join(cmd), flush=True)
subprocess.run(cmd, check=True)
PY

echo "[INFO] Done. Output: /output/curvature_streamlines.csv"
